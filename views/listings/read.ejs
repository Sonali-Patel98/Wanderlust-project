<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
        <div class="col-8 offset-3">
            <h3><%= idvalues.title%></h3>
        </div>
        <div class="card col-6 offset-3 show-card listing-card">
            <img src="<%= idvalues.image.url %>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <p class="card-text">
                    <%= idvalues.description%><br>
                    &#8377; <%= idvalues.price.toLocaleString("en-IN") %><br>
                    <%= idvalues.location%><br>
                    <%= idvalues.country%>
                </p>
            <div>
        </div>
        <div class="btns">
            <a href="/listing/<%=idvalues._id%>/edit" class="btn btn-dark add-btn col-md-2">Edit</a>
            <form method="post" action="/listing/<%=idvalues._id%>?_method=Delete">
                <button class=" btn btn-dark offset-5 del-btn">Delete</button>
            </form>
        </div>
        <hr>
        <div class="mb-3 show-card">
           <h4>Leave a Review</h4> 
           <form action="/listing/<%=idvalues._id%>/reviews" method="post" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
                </div>
                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comments</label>
                    <textarea 
                        name="review[comment]" 
                        id="comment" 
                        rows="5" 
                        cols="15"
                        class="form-control"
                        required
                    ></textarea>
                    <div class="invalid-feedback">Please add some comments foe review</div>
                </div>
                <button class="btn btn-outline-dark">Submit</button>
           </form>
           <hr>
           <p><b>All Reviews</b></p>
           <div class="row">
                <% for(let review of idvalues.reviews) {%>
                    <div class="card col-5 ms-3 mb-3">
                         <div class="card-body">
                            <h5 class="card-title"><%=idvalues.title  %></h5>
                            <p class="card-text"><%= review.comment %></p>
                            <p class="card-text"><%= review.rating %> stars</p>
                        </div>
                        <form 
                            class="mb-3" 
                            method="post" 
                            action="/listing/<%=idvalues._id%>/reviews/<%= review._id%>?_method=Delete"
                        >
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form>
                        
                    </div>
                <% } %>
            </div>
        </div>
    </div>
